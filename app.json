{
  "expo": {
    "name": "SilentGuardian",
    "slug": "silent-guardian",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0F4C3A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.silentguardian.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F4C3A"
      },
      "package": "com.silentguardian.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-linear-gradient"
    ],
    "scheme": "silentguardian"
  }
}
